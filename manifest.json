{
  "manifest_version": 3,
  "name": "AliPin & Etsy - Affiliate & Seller Assistant",
  "version": "1.1.0",
  "description": "Generate AliExpress affiliate links and create Pinterest pins instantly for both AliExpress and Etsy products.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "alarms",
    "tabs",
    "cookies",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://trends.google.com/*",
    "*://*.pinterest.com/*",
    "*://*.aliexpress.com/*",
    "*://*.youtube.com/*",
    "*://*.tiktok.com/*",
    "*://*.linktr.ee/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.aliexpress.com/w/*",
        "*://*.aliexpress.us/w/*",
        "*://*.aliexpress.ru/w/*"
      ],
      "js": ["sourcing_optimizer.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.aliexpress.com/item/*",
        "*://*.aliexpress.com/i/*",
        "*://*.aliexpress.com/w/*",
        "*://*.aliexpress.com/category/*",
        "*://*.aliexpress.com/store/*",
        "*://*.aliexpress.us/item/*",
        "*://*.aliexpress.us/i/*",
        "*://*.aliexpress.us/w/*",
        "*://*.aliexpress.us/category/*",
        "*://*.aliexpress.us/store/*",
        "*://*.aliexpress.ru/item/*",
        "*://*.aliexpress.ru/i/*",
        "*://*.aliexpress.ru/w/*",
        "*://*.aliexpress.ru/category/*",
        "*://*.aliexpress.ru/store/*",
        "*://portals.aliexpress.com/*",
        "*://*.etsy.com/listing/*",
        "*://*.etsy.com/*/listing/*"
      ],
      "js": ["content.js"]
    },
    {
      "matches": [
        "*://*.pinterest.com/pin/create/extension/*",
        "*://*.pinterest.com/pin-builder/*",
        "*://*.pinterest.com/pin/creation/*",
        "*://trends.pinterest.com/*"
      ],
      "js": ["pinterest_automation.js"],
      "run_at": "document_idle"
    }
  ]
}